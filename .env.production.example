APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
AI_HOST=0.0.0.0
AI_PORT=8100
AI_SERVICE_URL=http://ai:8100

POSTGRES_USER=soricall
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=soricall
DATABASE_URL=postgresql+psycopg://soricall:replace-with-strong-password@postgres:5432/soricall

JWT_SECRET=replace-with-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

STORAGE_BACKEND=s3
LOCAL_STORAGE_DIR=/tmp/soricall_uploads
RETAIN_VOICE_SAMPLES=false

# Firebase Cloud Messaging is optional until push delivery is enabled.
FCM_PROJECT_ID=
FCM_ACCESS_TOKEN=

# HTTPS endpoint accepting {"to", "from", "text"}; any 2xx response is success.
SMS_WEBHOOK_URL=
SMS_WEBHOOK_BEARER_TOKEN=
SMS_SENDER=
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
DEVICE_ACCESS_TOKEN_EXPIRE_DAYS=365

# Comma-separated browser origins allowed to call the API directly.
# Same-origin /soricall-api requests do not require CORS.
CORS_ORIGINS=https://example.com
